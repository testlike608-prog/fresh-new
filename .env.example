# ════════════════════════════════════════════════════════════════
#  Water Inspection System — Environment Variables
#  انسخ الملف ده لـ .env واملأه بقيمك الحقيقية
#  cp .env.example .env
# ════════════════════════════════════════════════════════════════

# ── AI API Keys ──────────────────────────────────────────────────
# مهم: متسبش مسافات حوالين الـ "=" — docker-compose بيقرأ الاسم
# والقيمة زي ما هي حرفيًا (مسافة زيادة = المتغير مش هيتلاقى في الكود)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GENAI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS (اختياري — افتراضياً * لـ LAN) ─────────────────────────
# عدّله لو عايز تقيّد الوصول لـ IP معين
# CORS_ORIGINS=http://192.168.1.100:8000

# ── Data directory ───────────────────────────────────────────────
# مش محتاج تعدله — الـ docker-compose بيحدده تلقائياً
# DATA_DIR=/app/data
